# Application-level permissions

[]
access = read : [ * ], write : [ admin, power, sc_admin ]

### EVENT TYPES

[eventtypes]
export = system


### PROPS

[props]
export = system


### TRANSFORMS

[transforms]
export = system


### LOOKUPS

[lookups]
export = system


### MACROS

[macros]
export = system


### COLLECTIONS

[collections]
export = system


### TAGS

[tags]
export = system


### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system


### SCAFFOLD PLACEHOLDER — REMOVED IN PR 18 (verdict-inspector)
# `_suit_hello` confirms the SUIT bundle pipeline is wired end-to-end.
# `export = none` keeps it out of cross-app discovery; the underscore prefix
# keeps it out of app nav. Still reachable via deep-link to authenticated
# users with app read — the rendered card identifies itself as a scaffold.

[views/_suit_hello]
export = none
