<!--
  PLACEHOLDER — REMOVE IN PR 18 (verdict-inspector).

  Hidden from app nav via the underscore prefix (Splunk convention for
  non-navigable views). `isVisible="false"` is NOT a valid <view> attribute
  and was previously a bug. Real access control lives in default.meta:
  `[views/_suit_hello] export = none` keeps this view from leaking across
  apps. It IS still reachable via deep-link to authenticated users with
  app read; the rendered card explicitly says "scaffold placeholder" so a
  deep-link prober sees that immediately.
-->
<view template="dashboards/template.dashboard.html"
      stylesheet="splunkgate-suit/tokens.css"
      script="splunkgate-suit/hello.js">
    <label>_SUIT scaffold check</label>
    <description>Placeholder view confirming the SUIT bundle pipeline is wired. Hidden from the nav via underscore prefix; removed in PR 18 (verdict-inspector) once all three real dashboards land.</description>
    <module name="HTML">
        <param name="html"><![CDATA[
            <div id="splunkgate-suit-hello"></div>
        ]]></param>
    </module>
</view>
